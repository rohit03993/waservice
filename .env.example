PROJECT_NAME=WhatsApp SaaS
API_V1_PREFIX=/api/v1
DEBUG=true
# Production: set false and disable public signup unless intended.
ALLOW_OPEN_REGISTRATION=true

POSTGRES_DB=msg_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/msg_service

REDIS_URL=redis://redis:6379/0
# Production: share rate limits across API workers (requires Redis).
RATE_LIMIT_USE_REDIS=false
# Set true only on a trusted network to expose /docs and /openapi.json when DEBUG=false.
EXPOSE_API_DOCS=false

JWT_SECRET_KEY=change-this-super-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Optional: set in production so tokens include a fixed issuer; mismatched iss is rejected.
# JWT_ISSUER=waservice
# Required in startup (generate Fernet key via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=replace-with-generated-fernet-key

# Sent.dm — SMS OTP login (https://docs.sent.dm/start/guides/sending-messages). Optional; leave empty to disable phone sign-in.
# Put real values only in `.env` (gitignored), not in this example file.
# SENT_DM_API_KEY=
# SENT_DM_TEMPLATE_ID=
# Variable name in your Sent template for the 6-digit code (must match the template exactly; Sent often uses "code").
# SENT_DM_OTP_PARAMETER_NAME=code
# PHONE_LOGIN_OTP_TTL_SECONDS=600

# Comma-separated browser origins allowed to call the API (your Next.js URL(s), HTTPS in prod).
CORS_ORIGINS=http://localhost:3000,http://localhost:3010
# Behind nginx/CloudPanel: Host names this API answers as (prevents Host header attacks). Example:
# TRUSTED_HOSTS=wa.example.com,api.example.com
# HTTPS only: send HSTS (seconds). Enable only when the site is always served over TLS.
# HSTS_MAX_AGE_SECONDS=31536000

# Optional: forward Meta webhook payloads to another CRM (HTTPS). Leave empty to disable.
# Does NOT change Meta callback URL — safe alongside live Wapaldigital inbox.
# EXTERNAL_CRM_WEBHOOK_URL=https://your-other-crm.com/webhooks/waservice
# EXTERNAL_CRM_WEBHOOK_SECRET=generate-a-long-random-string

# WhatsApp media cache (inbox images/docs). Default in Docker: /app/media_cache
# MEDIA_CACHE_DIR=/app/media_cache
